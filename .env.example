PORT=3000

DB_HOST=postgres
DB_PORT=5432
DB_USER=app
DB_PASSWORD=app
DB_NAME=ecommerce_db_hw
DB_SSL=false

# AWS S3 (Presigned URLs)
AWS_REGION=eu-central-1
S3_BUCKET=nodejs-homework-27

# For local dev (DO NOT commit real keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: use CloudFront for delivery
CLOUDFRONT_BASE_URL=

# Presign expiration (seconds)
FILES_PRESIGN_EXPIRES_SEC=120


# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
ORDERS_MAX_ATTEMPTS=3
ORDERS_RETRY_DELAY_MS=5000

# gRPC Payments (internal)
# Payments server bind address (payments-service)
PAYMENTS_GRPC_BIND=0.0.0.0:50051
# Orders client target (orders-service)
PAYMENTS_GRPC_URL=payments:50051
# Deadline/timeout for Orders → Payments calls
PAYMENTS_GRPC_TIMEOUT_MS=800
# Minimal currency for homework
PAYMENTS_CURRENCY=USD

# Security baseline
NODE_ENV=production
DB_LOG_QUERIES=false
ENABLE_HSTS=false
RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_TTL_MS=60000
RATE_LIMIT_STRICT_LIMIT=10
RATE_LIMIT_STRICT_TTL_MS=60000

